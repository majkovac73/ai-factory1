# Python bytecode and caches
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
ENV/
env/

# Environment files
.env
.env.*
!.env.example

# Logs and local data
logs/
*.log
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
*.db-journal

# Runtime artifacts — generated images, worker state, autonomy/spend ledgers.
# These are produced at runtime (Railway uses the /data volume), never source.
data/

# IDE and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp
*.bak
